{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://auth.onepeloton.com/**" },
        { "url": "https://api.onepeloton.com/**" }
      ]
    }
  ]
}
